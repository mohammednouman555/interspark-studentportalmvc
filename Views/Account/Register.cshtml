@model StudentPortalMVC.Models.RegisterViewModel

<h2>Register</h2>

<form method="post">

    <div class="mb-3">
        <label>Email</label>

        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>

        <input asp-for="Password"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Register
    </button>

</form>