@model StudentPortalMVC.Models.LoginViewModel

<h2>Login</h2>

<form method="post">

    <div class="mb-3">
        <label>Email</label>

        <input asp-for="Email"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>

        <input asp-for="Password"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-success">
        Login
    </button>

</form>